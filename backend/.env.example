PORT=4000
NODE_ENV=production
APP_STORAGE_MODE=database
DATABASE_URL="mysql://root:root@localhost:3306/pralux_hr_app"
CORS_ORIGINS=https://hr.pralux.co.id
API_BASE_URL=https://api.hr.pralux.co.id
APP_SESSION_SECRET=change-this-production-secret
APP_TRUST_PROXY=1
APP_SESSION_IDLE_TIMEOUT_MINUTES=5
APP_SESSION_MAX_LIFETIME_HOURS=168
APP_SESSION_MAX_CONCURRENT_PER_USER=3
APP_SESSION_TOUCH_INTERVAL_MINUTES=5
ENFORCE_BACKEND_AUTH=true
BOOTSTRAP_DEMO_DATA=false
IDEMPOTENCY_TTL_SECONDS=120
OPS_ALERT_ERROR_RATE_PERCENT=5
OPS_ALERT_P95_MS=1200
OPS_ALERT_QUEUE_DEPTH=25
RETENTION_ATTENDANCE_SELFIE_DAYS=30
RETENTION_REIMBURSEMENT_RECEIPT_DAYS=365
RETENTION_EMPLOYEE_DOCUMENT_DAYS=2555
RETENTION_AUDIT_LOG_DAYS=2555
